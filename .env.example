# ─── Discord Bot Token (Regular Bot Account) ───────────────────────────────
# Create at: https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_bot_client_id_here

# ─── Discord Self/User Token (User Account) ────────────────────────────────
# Required for presence tracking across servers
SELF_TOKEN=your_self_token_here

# ─── Platform Emoji IDs (Optional — Custom Emojis) ─────────────────────────
# Format: <:name:id> or <a:name:id> or a standard emoji
# Upload custom emojis to your server and paste their IDs below
EMOJI_DESKTOP=🖥️
EMOJI_MOBILE=📱
EMOJI_WEB=🌐
EMOJI_UNKNOWN=❓
